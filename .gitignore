# Nyaya Mitra — Root .gitignore

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
nyaya-mitra-app/.env

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/

# ── Node / Expo / Next.js ───────────────────────────────────────────────────
node_modules/
.expo/
web-build/
.next/
out/
.turbo/

# ── Data / generated artefacts ───────────────────────────────────────────────────
Raw_Data/
# Generated BM25 chunk store — large JSON, rebuild with: python etl_pipeline.py
# Never commit — grows with corpus, corrupts Git history permanently.
vector_store_mock.json
# Also catch any custom-named output stores
*_store.json
*_chunks.json

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Test cache ────────────────────────────────────────────────────────────────
.pytest_cache/
