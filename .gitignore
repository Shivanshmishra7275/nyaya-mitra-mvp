# Nyaya Mitra — Root .gitignore

# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
nyaya-mitra-app/.env

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/

# ── Node / Expo ───────────────────────────────────────────────────────────────
nyaya-mitra-app/node_modules/
nyaya-mitra-app/.expo/
nyaya-mitra-app/web-build/

# ── Data / generated artefacts ───────────────────────────────────────────────
Raw_Data/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Test cache ────────────────────────────────────────────────────────────────
.pytest_cache/
