# Nyaya Mitra — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional overrides (defaults shown) ──────────────────────────────────
# ChromaDB persistent storage path
CHROMA_DB_PATH=./chroma_db

# ChromaDB collection name
CHROMA_COLLECTION_NAME=nyaya_mitra_legal

# Sentence embedding model (Gemini embedding model ID)
EMBEDDING_MODEL=models/gemini-embedding-001

# Number of chunks to retrieve per query
RAG_TOP_K=15

# ── FastAPI server settings ────────────────────────────────────────────────
# These align with config.FASTAPI_HOST / FASTAPI_PORT
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Optional logging override (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional SQLite path override
SQLITE_DB_PATH=./nyaya_mitra.db
