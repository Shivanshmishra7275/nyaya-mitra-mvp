# Nyaya Mitra — Backend Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Gemini API Key (optional — BYOK is preferred) ────────────────────────────
# If set, used as fallback when no key is supplied per-request.
# Leave blank in production to force users to BYOK.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Admin Endpoint Secret ──────────────────────────────────────────────────
# Required to access /api/v1/admin/debug/* endpoints in production.
# In production with no secret set, admin routes return 404 (hardened).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Or:       openssl rand -hex 32
ADMIN_SECRET=

# ── Rate Limiting ───────────────────────────────────────────────────────
# Max legal-query requests per minute per IP. Default: 10.
RATE_LIMIT_PER_MINUTE=10

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development   # "development" | "production"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use "*" for development. In production, list your real URLs.
# Example: https://nyaya-mitra.onrender.com,http://localhost:19006
ALLOWED_ORIGINS=*

# ── Retrieval ─────────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=vector_store_mock.json
BM25_TOP_K=15

# ── Qdrant semantic retrieval (optional, free, local) ────────────────────────
# Enables hybrid BM25 + semantic retrieval (recommended for better results).
# Step 1: Install deps:  pip install sentence-transformers qdrant-client
# Step 2: Run Qdrant:    docker run -p 6333:6333 qdrant/qdrant
# Step 3: Ingest:        python etl_pipeline.py --qdrant
# Step 4: Set QDRANT_ENABLED=true below, then restart the API server.
QDRANT_ENABLED=false
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=nyaya_legal_chunks

# ── LLM Settings ──────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
