# Nyaya Mitra — Environment Variables
# =====================================
# Copy this file to .env and fill in your values.
# Run: cp .env.example .env
# NEVER commit .env to version control.

# ── Gemini API Key (optional — BYOK is preferred) ────────────────────────────
# If set, used as fallback when no key is supplied per-request.
# Leave blank in production to force users to BYOK.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development   # "development" | "production"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use "*" for development. In production, list your real URLs.
# Example: https://nyaya-mitra.onrender.com,http://localhost:19006
ALLOWED_ORIGINS=*

# ── Retrieval ─────────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=vector_store_mock.json
BM25_TOP_K=15

# ── Qdrant (optional semantic retrieval) ─────────────────────────────────────
# Set QDRANT_ENABLED=true and run Qdrant locally or on a free cloud tier.
# docker run -p 6333:6333 qdrant/qdrant
QDRANT_ENABLED=false
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=nyaya_legal_chunks

# ── LLM Settings ──────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
