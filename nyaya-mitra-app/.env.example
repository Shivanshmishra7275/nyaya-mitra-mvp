# nyaya-mitra-app/.env.example
# Copy to nyaya-mitra-app/.env and fill in values.
# Restart `npx expo start` after any change to this file.

# ── Backend API URL ───────────────────────────────────────────────────────────
# IMPORTANT: All EXPO_PUBLIC_ variables are baked into the JS bundle at build time.
# They are NOT secret — do not put API keys here.

# Android Emulator (default if not set):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000

# iOS Simulator (default if not set):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Physical device on same WiFi (replace with YOUR machine's LAN IP):
# Run `ipconfig` on Windows or `ifconfig en0` on Mac to find it.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8000

# Hosted backend (Render free tier or other):
# EXPO_PUBLIC_API_BASE_URL=https://nyaya-mitra-api.onrender.com

EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
